{
  "id": "com.mattermost-bsky-plugin.bluesky-unfurl",
  "name": "Bluesky URL Unfurl",
  "description": "Unfurls Bluesky (bsky.app) post URLs with rich previews: author, post text, images, and engagement stats.",
  "homepage_url": "https://github.com/mattermost-bsky-plugin/mattermost-bsky-plugin",
  "support_url": "https://github.com/mattermost-bsky-plugin/mattermost-bsky-plugin/issues",
  "version": "0.1.0",
  "min_server_version": "9.0.0",
  "server": {
    "executables": {
      "linux-arm64": "server/dist/plugin-linux-arm64"
    }
  },
  "settings_schema": {
    "header": "",
    "footer": "",
    "settings": [
      {
        "key": "ShowEngagementCounts",
        "display_name": "Show Engagement Counts",
        "type": "bool",
        "help_text": "Display likes, reposts, and reply counts on Bluesky post previews.",
        "default": true
      }
    ]
  }
}
